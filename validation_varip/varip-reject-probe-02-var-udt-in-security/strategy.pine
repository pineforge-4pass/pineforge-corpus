//
// varip-reject probe 02 — var UDT mutated inside request.security (POSITIVE)
//
// Purpose: companion to varip-reject probe 01. This is the *positive*
// case: a `var` (NOT `varip`) UDT field mutated inside a `request.security`
// callable. PineForge should ACCEPT this and the strategy should produce
// trades. Confirms that the `varip` rejection is targeted, not a
// blanket rejection of state inside security callables.
//
// Trade shape: long-only EMA cross on 1H higher TF, with a `var` UDT
// counter mutated inside the security callable to track HTF cross
// events. Entry when the HTF counter advances and current chart RSI > 50.
//
// TV setup: 15m chart, ETH-USDT-USDT, same window as
// data/ohlcv_ETH-USDT-USDT_15m.csv. Export the trade list to tv_trades.csv.
//@version=6
strategy("PF varip-reject probe 02 - var UDT in security", shorttitle="VRIP_p02_UDT", overlay=true,
     initial_capital=1000000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0, slippage=0,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=1,
     process_orders_on_close=false)

type Counter
    int hits = 0
    float last = 0.0

// var UDT at strategy scope, mutated each chart bar based on HTF security read.
var Counter c = Counter.new(0, 0.0)

htfCross() =>
    fastH = ta.ema(close, 9)
    slowH = ta.ema(close, 21)
    ta.crossover(fastH, slowH) ? 1 : 0

int htfFiredInt = request.security(syminfo.tickerid, "60", htfCross())
bool htfFired = htfFiredInt == 1

if htfFired
    c.hits := c.hits + 1
    c.last := close

rsiVal = ta.rsi(close, 14)

bool entryCond = c.hits > 0 and htfFired and not na(rsiVal) and rsiVal > 50.0
bool exitCond  = not na(rsiVal) and rsiVal < 40.0

if entryCond and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty=1, comment="entry long")
if exitCond and strategy.position_size > 0
    strategy.close("L", comment="exit long")
