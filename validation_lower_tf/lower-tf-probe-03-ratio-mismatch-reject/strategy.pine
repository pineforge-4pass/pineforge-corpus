// Lower-TF probe 03 — LTF >= script_tf rejection
//
// Purpose: REJECTION probe. ``request.security_lower_tf`` requires the
// requested LTF be strictly finer than the script's effective TF.
// Here we request "20" (20 minutes) with script_tf=15: req >= script
// → engine must reject as "LTF must be finer than script timeframe".
//
// Note: original probe was 4m-on-15m (15%4!=0); invalidated by the
// 1m corpus migration (4%1==0 makes 4m a valid LTF on 1m input).
// Two related gaps remain to file separately:
//   - "45S" on 1m: 60%45!=0 but engine sub-minute LTF gate incomplete
//   - "7" on 1m + script_tf=15: 15%7!=0 (input-passthrough mode);
//     engine PR #4 gates `req % input` but not `script % req` —
//     known engine bug.
//
// Expected behavior: engine throws "request.security_lower_tf:
// requested timeframe '20' is not finer than script timeframe '15'".
// No tv_trades.csv accompanies this probe.
//@version=6
strategy("PF lower-tf probe 03 - ratio mismatch reject", shorttitle="LTF_p03_REJ", overlay=true,
     initial_capital=1000000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0, slippage=0,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=1,
     process_orders_on_close=false)

// 30m LTF on script_tf=15: req >= script → engine rejects.
// 30 is a standard Pine TF (TV accepts in chart + security calls).
ltfCloses = request.security_lower_tf(syminfo.tickerid, "30", close)

float lastV = na
if array.size(ltfCloses) > 0
    lastV := array.get(ltfCloses, array.size(ltfCloses) - 1)

if not na(lastV) and lastV > close and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty=1)
if strategy.position_size > 0 and close < ta.ema(close, 21)
    strategy.close("L")
