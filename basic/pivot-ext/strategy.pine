//@version=6
strategy("Pivot Extension Strategy", overlay=true, use_bar_magnifier=false, initial_capital=1000000, currency=currency.USD, process_orders_on_close=false, pyramiding=1, commission_type=strategy.commission.percent, commission_value=0, slippage=0, default_qty_type=strategy.fixed, default_qty_value=1)
leftBars = input(4, "Pivot Lookback Left")
rightBars = input(2, "Pivot Lookback Right")
ph = ta.pivothigh(leftBars, rightBars)
pl = ta.pivotlow(leftBars, rightBars)
if (not na(pl))
	strategy.entry("PivExtLE", strategy.long, comment="PivExtLE")
if (not na(ph))
	strategy.entry("PivExtSE", strategy.short, comment="PivExtSE")
//plot(strategy.equity, title="equity", color=color.red, linewidth=2, style=plot.style_areabr)