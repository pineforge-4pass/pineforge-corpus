//
// Parity probe: timeframe.main_period gates entries on 15-minute chart
//
// TV_RUN_NEEDED: tv_trades.csv missing — capture in TradingView:
//   Symbol: ETHUSDT.P (Binance USDT-M Perpetual)  TF: 15m  Range: 2024-01-01..2024-06-01
//   Save List of Trades → tv_trades.csv in this directory.
//
// Purpose: verify timeframe.main_period returns the chart's timeframe string
//          (e.g. "15" for a 15-minute chart). Strategy gates entries on the
//          condition timeframe.main_period == "15" to confirm the value is
//          correct. On a 15m chart all entries should fire; on any other
//          timeframe no entries fire.
//@version=6
strategy("PF timeframe.main_period adaptive", shorttitle="PF_TF_MAINPERIOD",
     overlay=true, initial_capital=1000000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0, slippage=0,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=1,
     process_orders_on_close=false)

// Only enter when running on 15-minute data (corpus default).
// Use timeframe.main_period directly in comparison to avoid type-inference issues.
bool on_15m = timeframe.main_period == "15"

fast = ta.sma(close, 10)
slow = ta.sma(close, 30)

if on_15m and ta.crossover(fast, slow) and strategy.position_size <= 0
    strategy.entry("L", strategy.long)

if on_15m and ta.crossunder(fast, slow) and strategy.position_size >= 0
    strategy.entry("S", strategy.short)
