//
// syminfo-country-nasdaq-us-01
//
// Smoke probe: verifies syminfo.country derivation compiles and runs.
// The codegen derives country from the tickerid prefix via a lookup table
// (e.g. NASDAQ:AAPL -> "US"). Default data uses tickerid="UNKNOWN" which
// maps to na<string>() — acceptable.
//
// TV_RUN_NEEDED: No TV CSV required — smoke probe only.
//@version=6
strategy("PF syminfo-country-nasdaq-us-01", shorttitle="G2_SCOUNTRY_01",
    overlay=false, initial_capital=10000, currency=currency.USD,
    commission_type=strategy.commission.percent, commission_value=0, slippage=0)

// Access syminfo.country — should compile and run (returns na for "UNKNOWN" tickerid)
country = syminfo.country

// Also verify syminfo.main_tickerid in same probe
main_id = syminfo.main_tickerid

// Simple SMA crossover trades
fast = ta.sma(close, 10)
slow = ta.sma(close, 30)

if ta.crossover(fast, slow)
    strategy.entry("L", strategy.long)
if ta.crossunder(fast, slow)
    strategy.close("L")
