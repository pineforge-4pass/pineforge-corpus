// MTF probe 02 — two HTF closes (60m + 240m); long only when both close > prior bar close
// Isolates alignment of multiple request.security series.
//@version=6
strategy("PF MTF probe 02 — dual TF closes", shorttitle="MTF_p02", overlay=true,
     initial_capital=1000000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0, slippage=0,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=1,
     process_orders_on_close=false)

float h60 = request.security(syminfo.tickerid, "60", close, lookahead=barmerge.lookahead_off)
float h240 = request.security(syminfo.tickerid, "240", close, lookahead=barmerge.lookahead_off)

bool up60 = h60 > h60[1]
bool up240 = h240 > h240[1]
bool bothUp = up60 and up240

if bothUp and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty=1)

bool exitSig = not up60 and strategy.position_size > 0
if exitSig
    strategy.close("L")
