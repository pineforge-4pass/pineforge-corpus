//
// Smoke probe: chart.is_standard == true in batch engine
//
// Purpose: verify that chart.is_standard evaluates to true (all other
//          chart.is_* variants evaluate to false) in PineForge's batch
//          OHLCV engine. The runtime.error guard ensures the strategy
//          fails immediately if the constant is wrong. SMA cross provides
//          real trades for basic engine sanity.
//
// NOTE: No TV CSV required — this is an engine-only constant check.
//       chart.is_standard is always true in batch mode; no TV parity needed.
//@version=6
strategy("PF chart.is_standard smoke", shorttitle="PF_CHART_ISSTANDARD",
     overlay=true, initial_capital=1000000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0, slippage=0,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=1,
     process_orders_on_close=false)

// Guard: chart.is_standard must be true in batch mode.
if not chart.is_standard
    runtime.error("chart.is_standard is not true in batch engine — codegen bug")

// Guard: all non-standard chart types must be false.
if chart.is_heikinashi or chart.is_kagi or chart.is_linebreak or
     chart.is_pnf or chart.is_range or chart.is_renko
    runtime.error("a non-standard chart.is_* flag is true — codegen bug")

// Simple SMA cross to generate trades for engine sanity.
fast = ta.sma(close, 10)
slow = ta.sma(close, 30)

if ta.crossover(fast, slow) and strategy.position_size <= 0
    strategy.entry("L", strategy.long)

if ta.crossunder(fast, slow) and strategy.position_size >= 0
    strategy.entry("S", strategy.short)
