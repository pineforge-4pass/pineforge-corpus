//
// varip-counter-state-positive-01
//
// TV_RUN_NEEDED: tv_trades.csv missing — capture in TradingView:
//   Symbol: ETHUSDT.P (Binance USDT-M Perpetual)  TF: 15m  Range: 2024-01-01..2024-06-01
//   Save List of Trades → tv_trades.csv in this directory.
//
// Purpose: Demonstrates `varip` keyword passthrough — treated as `var` in
// PineForge batch mode (no intrabar tick semantics). The `varip int counter`
// accumulates across bars identical to a `var int counter` declaration.
//
// Trade shape: counter increments every bar; strategy enters long when
// counter % 50 == 0 (every 50th bar), exits 5 bars later via bar-count exit.
// Long-only, fixed qty, zero commission/slippage.
//@version=6
strategy("PF varip-counter-state-positive-01", shorttitle="VRIP_CTR_01", overlay=true,
     initial_capital=100000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0, slippage=0,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=1,
     process_orders_on_close=false)

// varip treated as var in PineForge batch mode.
// In TradingView it would persist intrabar; in PineForge it persists bar-to-bar only.
varip int counter = 0
varip int barsInTrade = 0

counter := counter + 1

bool entryCond = counter % 50 == 0 and strategy.position_size == 0
bool exitCond  = strategy.position_size > 0 and barsInTrade >= 5

if entryCond
    strategy.entry("L", strategy.long, qty=1, comment="varip-entry")
    barsInTrade := 0

if strategy.position_size > 0
    barsInTrade := barsInTrade + 1

if exitCond
    strategy.close("L", comment="varip-exit")
    barsInTrade := 0
