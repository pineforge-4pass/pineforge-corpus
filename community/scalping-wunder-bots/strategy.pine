// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Effort 01 — Reverse Logic Scalper — WunderTrading Compatible (TradingView Strategy Mode)
//@version=6
strategy('Sol 3m scalping', overlay=true, margin_long=0, margin_short=0, calc_on_every_tick=false, use_bar_magnifier=false, initial_capital=1000000, currency=currency.USD, process_orders_on_close=false, pyramiding=1, commission_type=strategy.commission.percent, commission_value=0, slippage=0, default_qty_type=strategy.fixed, default_qty_value=1)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 RISK & MONEY MANAGEMENT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
capital         = input.int(title='Capital ($)', defval=1000, step=100, minval=100, maxval=1000000, group="💰 Risk Management")
risk_per_trade  = input.float(title='Risk per Trade (%)', defval=1.0, step=0.1, minval=0.1, maxval=5.0, group="💰 Risk Management")
riskReward      = input.float(title='Risk:Reward Ratio', defval=2.0, step=0.1, minval=1.0, maxval=5.0, group="💰 Risk Management")
use_leverage    = input.int(title='Leverage', defval=5, minval=1, maxval=50, step=1, group="💰 Risk Management")
max_daily_loss  = input.float(title='Max Daily Loss (%)', defval=3.0, step=0.5, minval=1.0, maxval=10.0, group="💰 Risk Management")
max_positions   = input.int(title='Max Open Positions', defval=5, minval=1, maxval=10, step=1, group="💰 Risk Management", tooltip="Maximum number of positions that can be open simultaneously")

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 INDICATOR SETTINGS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Support & Resistance
sr_lookback     = input.int(title='S/R Lookback Period', defval=20, minval=5, maxval=100, group="📊 Support & Resistance")
sr_tolerance    = input.float(title='S/R Zone Width (%)', defval=0.3, step=0.1, minval=0.1, maxval=1.0, group="📊 Support & Resistance", tooltip="How close price must be to S/R level to trigger (as % of price)")

// Bollinger Bands
bb_length       = input.int(title='BB Length', defval=20, minval=5, maxval=50, group="📈 Bollinger Bands")
bb_mult         = input.float(title='BB Multiplier', defval=2.0, step=0.1, minval=1.0, maxval=4.0, group="📈 Bollinger Bands")
bb_src          = input.source(title='BB Source', defval=close, group="📈 Bollinger Bands")

// Moving Average Crosses
fast_ma_len     = input.int(title='Fast MA Length', defval=9, minval=3, maxval=50, group="🔀 MA Cross")
slow_ma_len     = input.int(title='Slow MA Length', defval=21, minval=10, maxval=100, group="🔀 MA Cross")
ma_type         = input.string(title='MA Type', defval='EMA', options=['EMA', 'SMA', 'WMA'], group="🔀 MA Cross")

// Filters
use_volume_filter = input.bool(title='Use Volume Filter', defval=true, group="🔧 Filters")
vol_mult        = input.float(title='Min Volume Multiplier', defval=1.2, step=0.1, minval=0.5, maxval=3.0, group="🔧 Filters", tooltip="Volume must be this multiple of 20-bar average")
use_atr_filter  = input.bool(title='Use ATR Volatility Filter', defval=true, group="🔧 Filters")
atr_min_mult    = input.float(title='Min ATR Multiplier', defval=0.5, step=0.1, minval=0.1, maxval=2.0, group="🔧 Filters", tooltip="Current ATR must be at least this multiple of 50-bar ATR average")
min_bars_between = input.int(title='Min Bars Between Entries', defval=3, minval=1, maxval=20, group="🔧 Filters", tooltip="Minimum bars between opening new positions to avoid clustering")

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 BACKTEST PERIOD
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
testStartYear   = input.int(2025, "Backtest Start Year", group="📅 Backtest Period")
testStartMonth  = input.int(1, "Backtest Start Month", group="📅 Backtest Period")
testStartDay    = input.int(1, "Backtest Start Day", group="📅 Backtest Period")
testPeriodStart = timestamp(testStartYear, testStartMonth, testStartDay, 0, 0)
testPeriod()    => time >= testPeriodStart

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 INDICATOR CALCULATIONS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// --- Support & Resistance via Pivot Points ---
pivot_high = ta.pivothigh(high, sr_lookback, sr_lookback)
pivot_low  = ta.pivotlow(low, sr_lookback, sr_lookback)

var float resistance_level = na
var float support_level    = na

if not na(pivot_high)
    resistance_level := pivot_high
if not na(pivot_low)
    support_level := pivot_low

// Proximity checks (how close price is to S/R zones)
sr_zone         = close * (sr_tolerance / 100)
near_resistance = not na(resistance_level) and math.abs(close - resistance_level) <= sr_zone
near_support    = not na(support_level) and math.abs(close - support_level) <= sr_zone

// --- Bollinger Bands ---
bb_basis = ta.sma(bb_src, bb_length)
bb_dev   = bb_mult * ta.stdev(bb_src, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_pct   = (close - bb_lower) / (bb_upper - bb_lower) // %B indicator (0 to 1)

// Conventional: buy below lower band, sell above upper band
// REVERSED: buy above upper band (breakout), sell below lower band (breakdown)
bb_long_signal  = close > bb_upper  // Price breaking above upper BB → reversed: go LONG
bb_short_signal = close < bb_lower  // Price breaking below lower BB → reversed: go SHORT

// --- Moving Average Cross ---
get_ma(src, length) =>
    switch ma_type
        'EMA' => ta.ema(src, length)
        'SMA' => ta.sma(src, length)
        'WMA' => ta.wma(src, length)

fast_ma = get_ma(close, fast_ma_len)
slow_ma = get_ma(close, slow_ma_len)

// Conventional: golden cross = buy, death cross = sell
// REVERSED: death cross = buy (anticipating exhaustion/reversal), golden cross = sell
ma_bearish_cross = ta.crossunder(fast_ma, slow_ma)  // Death cross → reversed: LONG signal
ma_bullish_cross = ta.crossover(fast_ma, slow_ma)   // Golden cross → reversed: SHORT signal

// --- Volume Filter ---
vol_avg   = ta.sma(volume, 20)
vol_ok    = not use_volume_filter or (volume >= vol_avg * vol_mult)

// --- ATR Volatility Filter ---
atr_val     = ta.atr(14)
atr_avg     = ta.sma(atr_val, 50)
atr_ok      = not use_atr_filter or (atr_val >= atr_avg * atr_min_mult)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 REVERSE LOGIC — SIGNAL GENERATION
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 
// CONVENTIONAL LOGIC (what most traders do):
//   LONG  = Price near support + below lower BB + golden cross
//   SHORT = Price near resistance + above upper BB + death cross
//
// REVERSED LOGIC (what this strategy does):
//   LONG  = Price near resistance + above upper BB + death cross
//           → Market expects rejection at resistance, but we bet on breakout
//           → BB breakout above = momentum continuation, not reversal
//           → Death cross = late-comers selling = trap before reversal up
//
//   SHORT = Price near support + below lower BB + golden cross
//           → Market expects bounce at support, but we bet on breakdown
//           → BB breakdown below = momentum continuation down
//           → Golden cross = late-comers buying = trap before reversal down
//
// WHY THIS CAN WORK:
//   Retail traders cluster stops at predictable S/R levels.
//   Institutions hunt these stops, creating the false breakout/breakdown
//   that this strategy rides. Combined with BB momentum confirmation
//   and contrary MA signals, we position with the institutional flow.
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Require at least 2 of 3 reversed conditions for entry
long_score  = (near_resistance ? 1 : 0) + (bb_long_signal ? 1 : 0) + (ma_bearish_cross ? 1 : 0)
short_score = (near_support ? 1 : 0) + (bb_short_signal ? 1 : 0) + (ma_bullish_cross ? 1 : 0)

reverse_long_condition  = long_score >= 2 and vol_ok and atr_ok
reverse_short_condition = short_score >= 2 and vol_ok and atr_ok

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 MULTI-POSITION TRACKING
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
var int   trade_counter    = 0       // Unique ID counter for each trade
var float daily_pnl        = 0.0
var int   last_trade_day   = 0
var int   bars_since_entry = 100     // Start high so first signal isn't blocked

// Increment bars since last entry on every bar
bars_since_entry += 1

// Reset daily P&L tracker
current_day = dayofmonth
if current_day != last_trade_day
    daily_pnl      := 0.0
    last_trade_day := current_day

// Check if daily loss limit is breached
daily_loss_ok = daily_pnl > -(capital * max_daily_loss / 100)

// Count currently open positions
open_trades = strategy.opentrades

// Can we open a new position?
can_open_new = open_trades < max_positions and bars_since_entry >= min_bars_between

// ATR-based stop loss distance
atr_stop_distance = atr_val * 1.5

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 TRADE EXECUTION — MULTIPLE POSITIONS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// In "TradingView Strategy" mode, WunderTrading reads order fill events
// directly from TradingView placeholders in the alert message:
//   {{strategy.order.action}}         → "buy" or "sell"
//   {{strategy.market_position}}      → "long", "short", or "flat"
//   {{strategy.market_position_size}} → current position size
//   {{strategy.order.contracts}}      → order quantity
//
// The JSON template is pasted into the TradingView alert message field.
// The Pine Script just needs to fire strategy.entry() / strategy.exit()
// normally — no custom JSON building or alert() calls needed.
//
// SL/TP are handled by strategy.exit() within TradingView's broker
// emulator. WunderTrading mirrors the resulting position changes.
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if testPeriod() and daily_loss_ok and can_open_new

    // === LONG ENTRY ===
    if reverse_long_condition
        trade_counter   += 1
        entry_price      = close
        stop_val         = close - atr_stop_distance
        take_val         = close + (atr_stop_distance * riskReward)
        
        // Position sizing based on risk (result is in contracts / base asset units)
        risk_amount      = capital * (risk_per_trade / 100)
        stop_dist_pct    = math.abs(entry_price - stop_val) / entry_price
        qty_contracts    = stop_dist_pct > 0 ? math.round(risk_amount / stop_dist_pct) / close : 0.0
        
        // Unique trade ID so each position has its own SL/TP
        trade_id = "Long_" + str.tostring(trade_counter)
        
        if qty_contracts > 0
            strategy.entry(trade_id, strategy.long, qty=qty_contracts)
            strategy.exit("Exit_" + str.tostring(trade_counter), from_entry=trade_id, limit=take_val, stop=stop_val)
            bars_since_entry := 0
    
    // === SHORT ENTRY ===
    if reverse_short_condition
        trade_counter   += 1
        entry_price      = close
        stop_val         = close + atr_stop_distance
        take_val         = close - (atr_stop_distance * riskReward)
        
        // Position sizing based on risk (result is in contracts / base asset units)
        risk_amount      = capital * (risk_per_trade / 100)
        stop_dist_pct    = math.abs(stop_val - entry_price) / entry_price
        qty_contracts    = stop_dist_pct > 0 ? math.round(risk_amount / stop_dist_pct) / close : 0.0
        
        // Unique trade ID so each position has its own SL/TP
        trade_id = "Short_" + str.tostring(trade_counter)
        
        if qty_contracts > 0
            strategy.entry(trade_id, strategy.short, qty=qty_contracts)
            strategy.exit("Exit_" + str.tostring(trade_counter), from_entry=trade_id, limit=take_val, stop=stop_val)
            bars_since_entry := 0

// Track daily P&L
if strategy.closedtrades > 0
    last_pnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if strategy.closedtrades != strategy.closedtrades[1]
        daily_pnl += last_pnl

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 VISUAL PLOTS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Support & Resistance levels
plot(resistance_level, 'Resistance', color=color.new(color.red, 30), linewidth=2, style=plot.style_stepline_diamond)
plot(support_level, 'Support', color=color.new(color.green, 30), linewidth=2, style=plot.style_stepline_diamond)

// Bollinger Bands
p_bb_upper = plot(bb_upper, 'BB Upper', color=color.new(color.blue, 60))
p_bb_lower = plot(bb_lower, 'BB Lower', color=color.new(color.blue, 60))
p_bb_basis = plot(bb_basis, 'BB Basis', color=color.new(color.orange, 40))
fill(p_bb_upper, p_bb_lower, color=color.new(color.blue, 92), title='BB Fill')

// Moving Averages
plot(fast_ma, 'Fast MA', color=color.new(color.yellow, 20), linewidth=2)
plot(slow_ma, 'Slow MA', color=color.new(color.purple, 20), linewidth=2)

// Entry signals (shown regardless of position state — multiple positions allowed)
plotshape(reverse_long_condition and can_open_new and daily_loss_ok and testPeriod(), 'Reverse Long', shape.triangleup, location.belowbar, color.new(color.lime, 0), size=size.small)
plotshape(reverse_short_condition and can_open_new and daily_loss_ok and testPeriod(), 'Reverse Short', shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 DASHBOARD TABLE
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
var table dashboard = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(dashboard, 0, 0, 'EFFORT 01', text_color=color.white, text_size=size.small, bgcolor=color.new(color.teal, 40))
    table.cell(dashboard, 1, 0, 'Dashboard', text_color=color.white, text_size=size.small, bgcolor=color.new(color.teal, 40))
    
    table.cell(dashboard, 0, 1, 'Open Trades', text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 1, str.tostring(open_trades) + ' / ' + str.tostring(max_positions), 
         text_color=open_trades >= max_positions ? color.orange : color.lime, text_size=size.small)
    
    table.cell(dashboard, 0, 2, 'Net Position', text_color=color.white, text_size=size.small)
    pos_text = strategy.position_size > 0 ? 'NET LONG' : strategy.position_size < 0 ? 'NET SHORT' : 'FLAT'
    table.cell(dashboard, 1, 2, pos_text, 
         text_color=strategy.position_size > 0 ? color.lime : strategy.position_size < 0 ? color.red : color.gray, text_size=size.small)
    
    table.cell(dashboard, 0, 3, 'Total Trades', text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 3, str.tostring(trade_counter), text_color=color.white, text_size=size.small)
    
    table.cell(dashboard, 0, 4, 'Long Score', text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 4, str.tostring(long_score) + '/3', text_color=color.lime, text_size=size.small)
    
    table.cell(dashboard, 0, 5, 'Short Score', text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 5, str.tostring(short_score) + '/3', text_color=color.red, text_size=size.small)
    
    table.cell(dashboard, 0, 6, 'ATR', text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 6, str.tostring(atr_val, '#.####'), text_color=color.orange, text_size=size.small)
    
    table.cell(dashboard, 0, 7, 'Daily P&L', text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 7, str.tostring(daily_pnl, '#.##'), text_color=daily_pnl >= 0 ? color.lime : color.red, text_size=size.small)
    
    table.cell(dashboard, 0, 8, 'Bars Since Entry', text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 8, str.tostring(bars_since_entry), text_color=color.white, text_size=size.small)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔵 WUNDERTRADING SETUP INSTRUCTIONS (TradingView Strategy Mode)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 
// This strategy is configured for WunderTrading's "TradingView Strategy" 
// start condition mode. In this mode, WunderTrading reads order fill events
// directly from TradingView placeholders — no custom JSON or alert() calls 
// are needed in the Pine Script.
//
// HOW TO SET UP:
// ──────────────
// 1. In WunderTrading Signal Bot settings:
//    - Bot start condition: "TradingView Strategy"
//    - Exchange: HyperLiquid Perps (or your exchange)
//    - Pair: BTC-USDC (or your pair)
//    - Timeframe: 3 Minute
//    - Leverage: 10 (or your preference)
//
// 2. Copy the "TradingView Strategy JSON" from the Signal Bot's Alerts panel.
//    It will look like this:
//    {
//      "code": "TV-STRATEGY_HyperLiquid_BTC-USDC_Scalping_3M_XXXXX",
//      "alertPrice": "{{close}}",
//      "alertTime": "{{timenow}}",
//      "recvWindow": "60000",
//      "action": "{{strategy.order.action}}",
//      "pos": "{{strategy.market_position}}",
//      "posSize": "{{strategy.market_position_size}}",
//      "prevPos": "{{strategy.prev_market_position}}",
//      "prevPosSize": "{{strategy.prev_market_position_size}}",
//      "amount": "{{strategy.order.contracts}}",
//      "amountin": "contracts",
//      "tvTicker": "{{ticker}}"
//    }
//
// 3. In TradingView, create a single alert:
//    - Condition: select "Effort 01"
//    - From the dropdown, select "Order fills only"
//    - In the Message tab, paste the JSON from step 2
//    - In Notifications, enable Webhook URL
//    - Paste the WebHook URL from WunderTrading:
//      https://wtalerts.com/bot/trading_view_strategy
//    - Click Create
//
// 4. That's it. Every strategy.entry() and strategy.exit() order fill
//    will automatically trigger the webhook with the correct placeholders
//    filled in by TradingView.
//
// HOW IT WORKS:
// ─────────────
// • strategy.entry("Long_X", strategy.long, ...) fires →
//   TradingView fills {{strategy.order.action}} = "buy",
//   {{strategy.market_position}} = "long", etc.
//
// • strategy.exit("Exit_X", ..., limit=TP, stop=SL) fires when
//   TP or SL is hit → TradingView fills action = "sell",
//   position changes accordingly.
//
// • WunderTrading reads these placeholders and mirrors the exact
//   position on your exchange via the API.
//
// STRATEGY: Effort 01 — Reverse Logic 3m Scalper
// TIMEFRAME: 3-minute (optimized for crypto scalping)
// MULTI-POSITION: Yes — up to max_positions simultaneously
// 
// REVERSE LOGIC EXPLAINED:
// ┌─────────────────────┬────────────────────────┬────────────────────────┐
// │ Element             │ Conventional Signal    │ Reversed Signal        │
// ├─────────────────────┼────────────────────────┼────────────────────────┤
// │ Support & Resistance│ Buy at support         │ SHORT at support       │
// │                     │ Sell at resistance      │ LONG at resistance     │
// ├─────────────────────┼────────────────────────┼────────────────────────┤
// │ Bollinger Bands     │ Buy below lower band   │ SHORT below lower band │
// │                     │ Sell above upper band   │ LONG above upper band  │
// ├─────────────────────┼────────────────────────┼────────────────────────┤
// │ MA Cross            │ Golden cross = Buy     │ Golden cross = SHORT   │
// │                     │ Death cross = Sell      │ Death cross = LONG     │
// └─────────────────────┴────────────────────────┴────────────────────────┘
//
// MULTI-POSITION SYSTEM:
//   - Each entry gets a unique ID (Long_1, Long_2, Short_3, etc.)
//   - Each position has its own independent SL and TP via strategy.exit()
//   - close_entries_rule = "ANY" ensures exits match to correct entry
//   - Positions close independently — one hitting SL doesn't affect others
//   - Max positions capped by user input (default 5)
//   - Min bars between entries prevents signal clustering
//
// SCORING: Requires 2 of 3 reversed conditions + volume + ATR filter
// RISK: ATR-based SL (1.5x ATR), configurable R:R, daily loss cap
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
