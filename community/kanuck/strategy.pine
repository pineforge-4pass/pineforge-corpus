//@version=6
strategy("Canuck Trading KAMA Strategy", shorttitle="CT_KAMA", overlay=true, calc_on_every_tick=true, max_bars_back=500, use_bar_magnifier=false, initial_capital=1000000, currency=currency.USD, process_orders_on_close=false, pyramiding=1, commission_type=strategy.commission.percent, commission_value=0, slippage=0, default_qty_type=strategy.fixed, default_qty_value=1)

// ═══════════════════════════════════════════════════════════════════════════
// CT KAMA v8.0 — Adaptive Position Sizing
//
// STATE (price + KAMA integrated)
//   Green = KAMA rising with acceleration AND close above KAMA
//   Red   = KAMA falling with deceleration AND close below KAMA
//   Gray  = anything else — transition or disagreement
//
// TRADE BEHAVIOUR
//   Hold     = ride the color, exit only on opposite color
//   Exit     = close when color turns gray
//   Adaptive = continuously scale position based on σ extension,
//              trend quality, and price action within bands
// ═══════════════════════════════════════════════════════════════════════════


// ─── Inputs ───────────────────────────────────────────────────────────────

// Strategy
string input_direction    = input.string("Long", "Trade Direction", options=["Long", "Short", "Both"], group="Strategy", tooltip="Long = longs only. Short = shorts only. Both = full reversal.")
string input_trade_mode   = input.string("Hold", "Trade Behaviour", options=["Hold", "Exit", "Adaptive"], group="Strategy", tooltip="Hold = hold through gray, exit only on opposite color. Exit = close position when color turns gray. Adaptive = dynamically scale position size based on band extension and trend quality.")
bool   input_use_dev_gate = input.bool(true, "Band Deviation Gate", group="Strategy", tooltip="When enabled, entries are blocked if price is more than Max Entry Deviation σ from fair value.")
float  input_max_dev      = input.float(1.5, "Max Entry Deviation (σ)", minval=0.1, maxval=5.0, step=0.1, group="Strategy", tooltip="Maximum σ distance from KAMA to allow new entries. Default 1.5σ.")

// Adaptive
float  input_trim_start   = input.float(1.0, "Trim Start (σ)", minval=0.3, maxval=3.0, step=0.1, group="Adaptive", tooltip="σ distance from KAMA where position trimming begins. Default 1.0σ.")
float  input_trim_step    = input.float(20.0, "Trim Step (%)", minval=5.0, maxval=50.0, step=5.0, group="Adaptive", tooltip="Percentage of original position to trim at each σ threshold. Default 20%.")
float  input_min_hold     = input.float(25.0, "Min Hold (%)", minval=10.0, maxval=75.0, step=5.0, group="Adaptive", tooltip="Minimum position size as % of original. Never trim below this floor. Default 25%.")
float  input_reload_buf   = input.float(0.5, "Reload Buffer", minval=0.1, maxval=1.0, step=0.1, group="Adaptive", tooltip="Reload triggers at this fraction of the trim distance. 0.5 = reload halfway back. Default 0.5.")
float  input_trend_shift  = input.float(0.5, "Trend Quality Shift (σ)", minval=0.0, maxval=2.0, step=0.1, group="Adaptive", tooltip="In strong trends (high ER + acceleration), trim thresholds shift out by this amount. Default 0.5σ.")
int    input_cooldown     = input.int(2, "Cooldown (bars)", minval=0, maxval=10, group="Adaptive", tooltip="Minimum bars between adaptive trim/reload actions. Prevents churning. Default 2.")

// KAMA Engine
int    input_er_len       = input.int(10, "ER Length", minval=2, maxval=50, group="KAMA Engine", tooltip="Efficiency Ratio lookback period. Higher = smoother, slower to react. Default 10.")
int    input_fast_period  = input.int(2, "Fast Period", minval=2, maxval=10, group="KAMA Engine", tooltip="KAMA fast smoothing constant period. Lower = faster response in trends. Default 2.")
int    input_slow_period  = input.int(30, "Slow Period", minval=10, maxval=100, group="KAMA Engine", tooltip="KAMA slow smoothing constant period. Higher = more filtering in chop. Default 30.")
int    input_dev_len      = input.int(20, "Deviation Length", minval=5, maxval=100, group="KAMA Engine", tooltip="Lookback for band deviation calculation. Default 20.")
float  input_band_mult    = input.float(2.0, "Band Multiplier", minval=0.5, maxval=5.0, step=0.25, group="KAMA Engine", tooltip="Band width as multiple of standard deviation from KAMA. Default 2.0.")

// Style
color  input_col_bull    = input.color(#00e676, "Trending Up",   group="Style")
color  input_col_bear    = input.color(#ff1744, "Trending Down", group="Style")
color  input_col_neutral = input.color(#787b86, "Coiling",       group="Style")
color  input_col_band    = input.color(#2962ff, "Bands",         group="Style")
int    input_kama_width  = input.int(3, "Fair Value Line Width", minval=1, maxval=5, group="Style")

// Display
bool   input_show_dash = input.bool(true, "Show Dashboard", group="Display")
string input_dash_pos  = input.string("Top Right", "Position", options=["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right","Middle Left"], group="Display")
string input_dash_size = input.string("Small", "Text Size", options=["Tiny","Small","Normal"], group="Display")
bool   input_show_bands = input.bool(true, "Show Bands",   group="Display")
bool   input_show_sigs  = input.bool(true, "Show Signals", group="Display")

// Theme
color  input_th_accent = input.color(#ff9800, "Accent",            group="Theme")
color  input_th_label  = input.color(#787b86, "Labels",            group="Theme")
color  input_th_hdr_bg = input.color(#0d1117, "Header Background", group="Theme")
color  input_th_bg1    = input.color(#131722, "Row Background",    group="Theme")
color  input_th_bg2    = input.color(#1e222d, "Alt Background",    group="Theme")
color  input_th_border = input.color(#363a45, "Border",            group="Theme")


// ═══════════════════════════════════════════════════════════════════════════
// SECTION 1: KAMA ENGINE
// ═══════════════════════════════════════════════════════════════════════════

int   ER_LEN      = input_er_len
int   FAST_PERIOD = input_fast_period
int   SLOW_PERIOD = input_slow_period
int   DEV_LEN     = input_dev_len
float BAND_MULT   = input_band_mult

float net_move   = math.abs(close - close[ER_LEN])
float total_path = math.sum(math.abs(close - close[1]), ER_LEN)
float er         = total_path != 0.0 ? net_move / total_path : 0.0

float fast_sc = 2.0 / (FAST_PERIOD + 1)
float slow_sc = 2.0 / (SLOW_PERIOD + 1)
float sc      = math.pow(er * (fast_sc - slow_sc) + slow_sc, 2)

var float kama = na
kama          := na(kama[1]) ? close : kama[1] + sc * (close - kama[1])

float kama_dev   = math.sqrt(ta.sma(math.pow(close - kama, 2), DEV_LEN))
float band_upper = kama + BAND_MULT * kama_dev
float band_lower = kama - BAND_MULT * kama_dev
float band_width = band_upper - band_lower
float band_pos   = band_width > 0.0 ? (close - band_lower) / band_width : 0.5
bool  in_lower_z = band_pos <= 0.33
bool  in_upper_z = band_pos >= 0.67
bool  in_mid_z   = not in_lower_z and not in_upper_z

float bw_pct      = kama > 0.0 ? band_width / kama * 100.0 : 0.0
float bw_avg      = ta.sma(bw_pct, DEV_LEN)
float bw_ratio    = nz(bw_avg) > 0.0 ? bw_pct / bw_avg : 1.0
float bwr_long_avg = ta.ema(bw_ratio, DEV_LEN * 2)
float bwr_dev      = ta.ema(math.abs(bw_ratio - bwr_long_avg), DEV_LEN)
bool  volatile_mkt = bw_ratio > bwr_long_avg + bwr_dev
bool  tight_coil   = bw_ratio < bwr_long_avg - bwr_dev

float dist_from_fv_norm = kama_dev > 0.0 ? (close - kama) / kama_dev : 0.0
float abs_dist          = math.abs(dist_from_fv_norm)

float sc_threshold = math.sqrt(math.pow(slow_sc, 2) * math.pow(fast_sc, 2))
bool  is_choppy    = sc < sc_threshold


// ═══════════════════════════════════════════════════════════════════════════
// SECTION 2: MARKET STATE
// ═══════════════════════════════════════════════════════════════════════════

float kama_slope_raw = kama - kama[1]
float kama_slope     = ta.ema(kama_slope_raw, 3)
bool  slope_accel    = kama_slope > kama_slope[1]

bool is_green = not is_choppy and kama_slope > 0.0 and (slope_accel or slope_accel[1]) and close > kama
bool is_red   = not is_choppy and kama_slope < 0.0 and not slope_accel and not slope_accel[1] and close < kama
bool is_gray  = not is_green and not is_red

// ER metrics
float er_avg          = ta.ema(er, DEV_LEN)
float er_change_rate  = ta.ema(math.abs(er - er[1]), 5)
float er_noise_floor  = math.max(er_avg * 0.6, 0.1)
float er_strong_thresh = math.min(er_avg + er_change_rate * 4.0, 0.85)
bool  er_rising        = er > er[1]
float er_slope         = ta.ema(er - er[3], 3)
bool  er_building      = er_slope > 0.0 and er > er_noise_floor
float coil_ratio       = math.sum(is_gray ? 1 : 0, ER_LEN) / ER_LEN
bool  mostly_coiling   = coil_ratio > 0.5

// Trend quality — used by adaptive mode to shift trim thresholds
bool  strong_trend = er >= er_strong_thresh and slope_accel

// Price action — candle character for adaptive decisions
float body_size  = math.abs(close - open)
float full_range = high - low
float body_ratio = full_range > 0.0 ? body_size / full_range : 0.5
float upper_wick = high - math.max(open, close)
float lower_wick = math.min(open, close) - low
float wick_ratio_upper = full_range > 0.0 ? upper_wick / full_range : 0.0
float wick_ratio_lower = full_range > 0.0 ? lower_wick / full_range : 0.0
bool  rejection_top    = wick_ratio_upper > 0.4 and in_upper_z
bool  rejection_bottom = wick_ratio_lower > 0.4 and in_lower_z


// ═══════════════════════════════════════════════════════════════════════════
// SECTION 3: POSITION STATE
// ═══════════════════════════════════════════════════════════════════════════

bool in_long  = strategy.position_size > 0
bool in_short = strategy.position_size < 0
bool in_trade = in_long or in_short
bool flat     = not in_trade


// ═══════════════════════════════════════════════════════════════════════════
// SECTION 4: ENTRIES AND EXITS
// ═══════════════════════════════════════════════════════════════════════════

// ── State tracking ────────────────────────────────────────────────────────
bool long_goes_gray   = in_long  and is_gray and not is_gray[1]
bool short_goes_gray  = in_short and is_gray and not is_gray[1]
bool long_goes_red    = in_long  and is_red
bool short_goes_green = in_short and is_green

bool new_position = (in_long and not in_long[1]) or (in_short and not in_short[1])

var float original_qty     = na
var float peak_sigma       = 0.0
var float current_pct      = 1.0
var int   bars_since_adj   = 0
var string last_adapt_action = "NONE"

if new_position
    original_qty     := math.abs(strategy.position_size)
    peak_sigma       := abs_dist
    current_pct      := 1.0
    bars_since_adj   := 0
    last_adapt_action := "ENTRY"

if flat
    original_qty     := na
    peak_sigma       := 0.0
    current_pct      := 1.0
    bars_since_adj   := 0
    last_adapt_action := "NONE"

if in_trade and not new_position
    bars_since_adj += 1
    if abs_dist > peak_sigma
        peak_sigma := abs_dist

// ── Band deviation gate (entries only) ────────────────────────────────────
bool dev_ok = not input_use_dev_gate or abs_dist <= input_max_dev

// ── HOLD mode ─────────────────────────────────────────────────────────────
if input_trade_mode == "Hold"
    if long_goes_red
        strategy.close("Long", comment="Color Ended")
    if short_goes_green
        strategy.close("Short", comment="Color Ended")

// ── EXIT mode ─────────────────────────────────────────────────────────────
if input_trade_mode == "Exit"
    if in_long and not is_green
        strategy.close("Long", comment="Color Ended")
    if in_short and not is_red
        strategy.close("Short", comment="Color Ended")

// ── ADAPTIVE mode — trim / reload / exit ──────────────────────────────────
if input_trade_mode == "Adaptive" and in_trade and not new_position

    // Opposite color = full close (same as Hold)
    if long_goes_red
        strategy.close("Long", comment="Color Ended")
        last_adapt_action := "EXIT"
    else if short_goes_green
        strategy.close("Short", comment="Color Ended")
        last_adapt_action := "EXIT"

    else if not na(original_qty) and original_qty > 0

        // Trend quality shift — delay trims in strong trends
        float _shift    = strong_trend ? input_trend_shift : 0.0
        // Rejection wick accelerates trims (reduce shift)
        float _pa_shift = (in_long and rejection_top) or (in_short and rejection_bottom) ? -0.25 : 0.0
        float _eff_shift = math.max(_shift + _pa_shift, 0.0)

        // Gray penalizes — tighten thresholds when color lost
        float _gray_penalty = is_gray ? 0.25 : 0.0

        float _trim_thresh  = input_trim_start + _eff_shift - _gray_penalty
        float _step_frac    = input_trim_step / 100.0
        float _min_frac     = input_min_hold / 100.0
        bool  _cooldown_ok  = bars_since_adj >= input_cooldown

        // How many trim steps deep are we?
        float _trim_depth = abs_dist > _trim_thresh ? (abs_dist - _trim_thresh) / math.max(_trim_thresh * 0.5, 0.25) : 0.0
        float _trim_frac  = math.min(_trim_depth * _step_frac, 1.0 - _min_frac)
        float _target_pct = math.max(1.0 - _trim_frac, _min_frac)

        // Reload — price reverting toward KAMA
        float _reload_thresh = peak_sigma * input_reload_buf
        bool  _color_ok      = (in_long and is_green) or (in_short and is_red)
        bool  _reload_zone   = abs_dist < _reload_thresh and _color_ok
        if _reload_zone
            _target_pct := math.max(_target_pct, math.min(current_pct + _step_frac, 1.0))

        // Execute adjustment if target differs from current by at least one step
        float _pct_diff = _target_pct - current_pct
        bool  _sig_change = math.abs(_pct_diff) >= _step_frac * 0.5

        if _cooldown_ok and _sig_change
            float _target_qty  = math.max(original_qty * _target_pct, 1.0)
            float _current_qty = math.abs(strategy.position_size)
            float _delta       = _target_qty - _current_qty

            if _delta < 0 and math.abs(_delta) >= 1.0
                // Trim — partial close of current position
                strategy.close(in_long ? "Long" : "Short", qty=math.abs(_delta), comment="Adapt Trim")
                current_pct      := _target_pct
                bars_since_adj   := 0
                last_adapt_action := "TRIM"

            else if _delta > 0 and _color_ok and dev_ok
                // Reload — add to current position, same direction
                strategy.order(in_long ? "Long" : "Short", in_long ? strategy.long : strategy.short, qty=_delta, comment="Adapt Reload")
                current_pct      := _target_pct
                bars_since_adj   := 0
                last_adapt_action := "RELOAD"

// ── Entries ───────────────────────────────────────────────────────────────
bool color_long  = flat and is_green and dev_ok and input_direction != "Short"
bool color_short = flat and is_red   and dev_ok and input_direction != "Long"

if color_long
    strategy.entry("Long",  strategy.long,  comment="Trend Long")
if color_short
    strategy.entry("Short", strategy.short, comment="Trend Short")

bool any_long_entry  = color_long
bool any_short_entry = color_short


// ═══════════════════════════════════════════════════════════════════════════
// SECTION 5: POSITION TRACKING
// ═══════════════════════════════════════════════════════════════════════════

var float entry_close = na
if new_position
    entry_close := close[1]

float sigma_moved = in_long ? (close - entry_close) / math.max(kama_dev, 1e-10) : in_short ? (entry_close - close) / math.max(kama_dev, 1e-10) : 0.0

var int pos_age = 0
if new_position
    pos_age := 1
else if in_trade
    pos_age += 1
else
    pos_age := 0


// ═══════════════════════════════════════════════════════════════════════════
// SECTION 6: CHART VISUALS
// ═══════════════════════════════════════════════════════════════════════════

color state_color = is_green ? input_col_bull : is_red ? input_col_bear : input_col_neutral
p_kama = plot(kama, "Fair Value", state_color, linewidth=input_kama_width)

color band_color = input_show_bands ? color.new(input_col_band, 65) : na
p_up = plot(band_upper, "Upper Band", band_color, linewidth=1)
p_dn = plot(band_lower, "Lower Band", band_color, linewidth=1)
fill(p_kama, p_up, color=na, title="Upper Zone")
fill(p_kama, p_dn, color=na, title="Lower Zone")

plotshape(any_long_entry  and input_show_sigs, "Buy",  shape.triangleup,   location.belowbar, input_col_bull, size=size.tiny)
plotshape(any_short_entry and input_show_sigs, "Sell", shape.triangledown, location.abovebar, input_col_bear, size=size.tiny)


// ═══════════════════════════════════════════════════════════════════════════
// SECTION 7: DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

string _dash_pos = switch input_dash_pos
    "Top Right"    => position.top_right
    "Top Left"     => position.top_left
    "Bottom Right" => position.bottom_right
    "Bottom Left"  => position.bottom_left
    "Middle Right" => position.middle_right
    "Middle Left"  => position.middle_left
    => position.top_right

string _sz = switch input_dash_size
    "Tiny"   => size.tiny
    "Normal" => size.normal
    => size.small

string _hdr_sz = switch input_dash_size
    "Tiny"   => size.tiny
    "Normal" => size.small
    => size.small

var table dash = na
if input_show_dash
    if na(dash)
        dash := table.new(_dash_pos, columns=2, rows=11, bgcolor=color.new(input_th_bg1, 0), border_width=1, border_color=color.new(input_th_border, 30), frame_width=2, frame_color=color.new(input_th_border, 0))

    color _bg0 = color.new(input_th_hdr_bg, 0)
    color _bg1 = color.new(input_th_bg1,    0)
    color _bg2 = color.new(input_th_bg2,    0)
    color _lbl = input_th_label
    color _acc = input_th_accent

    bool  _live    = strategy.position_size != 0
    float _pnl     = strategy.openprofit
    float _avg     = strategy.position_avg_price
    float _pnl_pct = _avg > 0.0 and _live ? (close / _avg - 1.0) * 100.0 * (in_long ? 1.0 : -1.0) : 0.0

    // Row 0: Header
    table.cell(dash, 0, 0, "CT KAMA", text_color=_acc, text_size=_hdr_sz, text_halign=text.align_left, bgcolor=_bg0)
    table.cell(dash, 1, 0, "v8.0",    text_color=_lbl, text_size=_hdr_sz, text_halign=text.align_right, bgcolor=_bg0)

    // Row 1: Price
    table.cell(dash, 0, 1, "Price", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg1)
    table.cell(dash, 1, 1, str.tostring(close, format.mintick), text_color=color.white, text_size=_sz, text_halign=text.align_right, bgcolor=_bg1)

    // Row 2: Fair Value
    table.cell(dash, 0, 2, "Fair Value", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg2)
    table.cell(dash, 1, 2, str.tostring(kama, format.mintick), text_color=state_color, text_size=_sz, text_halign=text.align_right, bgcolor=_bg2)

    // Row 3: Market State
    string _state_t = is_green ? "▲ TRENDING UP" : is_red ? "▼ TRENDING DOWN" : tight_coil ? "◈ COILING TIGHT" : "◈ COILING"
    color  _state_c = is_green ? input_col_bull  : is_red ? input_col_bear    : tight_coil ? input_col_band   : input_col_neutral
    table.cell(dash, 0, 3, "Market", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg1)
    table.cell(dash, 1, 3, _state_t,  text_color=_state_c, text_size=_sz, text_halign=text.align_right, bgcolor=_bg1)

    // Row 4: Signal
    bool   _h_in  = in_long or in_short
    string _sig_t = long_goes_red or short_goes_green ? "✕ COLOR ENDED" : (long_goes_gray or short_goes_gray) and input_trade_mode == "Exit" ? "✕ COLOR ENDED" : color_long ? "▲ TREND LONG" : color_short ? "▼ TREND SHORT" : _h_in and last_adapt_action == "TRIM" and bars_since_adj < 2 ? "◑ ADAPT TRIM" : _h_in and last_adapt_action == "RELOAD" and bars_since_adj < 2 ? "▲ ADAPT RELOAD" : is_green ? "● GREEN — WATCHING" : is_red ? "● RED — WATCHING" : _h_in and is_gray ? "◈ GRAY — HOLDING" : "◈ GRAY"
    color  _sig_c = long_goes_red or short_goes_green ? input_col_bear : (long_goes_gray or short_goes_gray) and input_trade_mode == "Exit" ? input_col_bear : color_long ? input_col_bull : color_short ? input_col_bear : _h_in and last_adapt_action == "TRIM" and bars_since_adj < 2 ? _acc : _h_in and last_adapt_action == "RELOAD" and bars_since_adj < 2 ? input_col_bull : is_green ? input_col_bull : is_red ? input_col_bear : _h_in and is_gray ? _acc : _lbl
    table.cell(dash, 0, 4, "Signal", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg2)
    table.cell(dash, 1, 4, _sig_t,   text_color=_sig_c, text_size=_sz, text_halign=text.align_right, bgcolor=_bg2)

    // Row 5: Position + Size + Value
    float _pos_val = math.abs(strategy.position_size) * close
    float _pos_pct = strategy.equity > 0 ? _pos_val / strategy.equity * 100.0 : 0.0
    string _pos_t = in_long ? "● LONG  " + str.tostring(strategy.position_size, "#.##") + "  $" + str.tostring(_pos_val, "#,###.##") + " (" + str.tostring(_pos_pct, "#.#") + "%)" : in_short ? "● SHORT  " + str.tostring(math.abs(strategy.position_size), "#.##") + "  $" + str.tostring(_pos_val, "#,###.##") + " (" + str.tostring(_pos_pct, "#.#") + "%)" : "─"
    color  _pos_c = in_long ? input_col_bull : in_short ? input_col_bear : _lbl
    table.cell(dash, 0, 5, "Position", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg1)
    table.cell(dash, 1, 5, _pos_t,     text_color=_pos_c, text_size=_sz, text_halign=text.align_right, bgcolor=_bg1)

    // Row 6: P&L
    string _pnl_pfx = _pnl >= 0.0 ? "+" : ""
    string _pnl_t   = _live ? _pnl_pfx + str.tostring(_pnl, "#.##") + "  (" + str.tostring(_pnl_pct, "#.##") + "%)" : "─"
    color  _pnl_c   = _pnl > 0.0 ? input_col_bull : _pnl < 0.0 ? input_col_bear : _lbl
    table.cell(dash, 0, 6, "P&L", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg2)
    table.cell(dash, 1, 6, _pnl_t, text_color=_live ? _pnl_c : _lbl, text_size=_sz, text_halign=text.align_right, bgcolor=_bg2)

    // Row 7: Efficiency Ratio
    color  _er_c = er >= er_strong_thresh ? input_col_bull : er >= er_noise_floor ? _acc : input_col_bear
    string _er_l = er >= er_strong_thresh ? "TRENDING" : er >= er_noise_floor ? "BUILDING" : "COILING"
    string _cr_t = mostly_coiling ? "  COIL " + str.tostring(coil_ratio * 100.0, "#") + "%" : ""
    table.cell(dash, 0, 7, "ER", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg1)
    table.cell(dash, 1, 7, str.tostring(er, "#.###") + (er_rising ? " ◆ " : " ◇ ") + _er_l + _cr_t, text_color=_er_c, text_size=_sz, text_halign=text.align_right, bgcolor=_bg1)

    // Row 8: Band Position
    string _zone_t = in_lower_z ? "LOWER" : in_upper_z ? "UPPER" : "MID"
    string _vol_t  = volatile_mkt ? "VOLATILE" : tight_coil ? "TIGHT COIL" : ""
    string _bnd_t  = str.tostring(band_pos, "#.##") + " " + _zone_t + (_vol_t != "" ? "  " + _vol_t : "")
    color  _bnd_c  = volatile_mkt ? input_col_bear : tight_coil ? input_col_band : in_mid_z ? _acc : input_col_band
    table.cell(dash, 0, 8, "Band", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg2)
    table.cell(dash, 1, 8, _bnd_t, text_color=_bnd_c, text_size=_sz, text_halign=text.align_right, bgcolor=_bg2)

    // Row 9: Development
    string _dev_t = _h_in ? str.tostring(sigma_moved, "#.##") + "σ  age:" + str.tostring(pos_age) + "  dist:" + str.tostring(dist_from_fv_norm, "#.##") + "σ" : "─"
    float  _dev_thresh = input_use_dev_gate ? input_max_dev : 1.5
    color  _dev_c = not _h_in ? _lbl : abs_dist > _dev_thresh ? _acc : _lbl
    table.cell(dash, 0, 9, "Dev", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg1)
    table.cell(dash, 1, 9, _dev_t,     text_color=_dev_c, text_size=_sz, text_halign=text.align_right, bgcolor=_bg1)

    // Row 10: Adaptive Status (only shows in Adaptive mode when in a trade)
    string _adp_t = "─"
    color  _adp_c = _lbl
    if input_trade_mode == "Adaptive" and _h_in
        string _act_t = last_adapt_action
        _adp_t := str.tostring(current_pct * 100.0, "#") + "%  pk:" + str.tostring(peak_sigma, "#.##") + "σ  " + _act_t
        _adp_c := current_pct >= 0.9 ? input_col_bull : current_pct >= 0.5 ? _acc : input_col_bear
    table.cell(dash, 0, 10, "Adaptive", text_color=_lbl, text_size=_sz, text_halign=text.align_left, bgcolor=_bg2)
    table.cell(dash, 1, 10, _adp_t, text_color=_adp_c, text_size=_sz, text_halign=text.align_right, bgcolor=_bg2)
