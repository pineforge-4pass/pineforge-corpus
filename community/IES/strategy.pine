strategy("Integrated Execution System [JOAT]", shorttitle="IES [JOAT]", overlay=true, calc_on_every_tick=true, max_bars_back=500, use_bar_magnifier=false, initial_capital=1000000, currency=currency.USD, process_orders_on_close=false, pyramiding=1, commission_type=strategy.commission.percent, commission_value=0, slippage=0, default_qty_type=strategy.fixed, default_qty_value=1)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// INTEGRATED EXECUTION SYSTEM
// Quantitative Trading Systems - Multi-Layer Strategy with Regime-Adaptive Logic
// Purpose: Execute trades based on regime, bias, momentum, and structure confluence
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

//───────────────────────────────────────────────────────────────────────────────
// CONFIGURATION - REGIME
//───────────────────────────────────────────────────────────────────────────────

g_regime = "═══════════ Regime Detection ═══════════"
int     i_adx_len       = input.int(14, "ADX Period", minval=5, maxval=30, group=g_regime)
float   i_adx_trend     = input.float(25, "Trend Threshold", minval=15, maxval=40, group=g_regime)
int     i_atr_len       = input.int(14, "ATR Period", minval=5, maxval=30, group=g_regime)
float   i_vol_exp       = input.float(1.4, "Volatility Expansion", minval=1.1, maxval=2.0, step=0.1, group=g_regime)
float   i_vol_con       = input.float(0.6, "Volatility Contraction", minval=0.3, maxval=0.9, step=0.1, group=g_regime)
bool    i_avoid_volatile = input.bool(true, "Avoid Volatile Regime", group=g_regime)

//───────────────────────────────────────────────────────────────────────────────
// CONFIGURATION - BIAS
//───────────────────────────────────────────────────────────────────────────────

g_bias = "═══════════ Directional Bias ═══════════"
int     i_ma_fast       = input.int(21, "Fast MA", minval=5, maxval=50, group=g_bias)
int     i_ma_slow       = input.int(55, "Slow MA", minval=20, maxval=200, group=g_bias)
int     i_ma_trend      = input.int(200, "Trend MA", minval=50, maxval=500, group=g_bias)
float   i_bias_thresh   = input.float(30, "Bias Threshold", minval=10, maxval=60, group=g_bias)

//───────────────────────────────────────────────────────────────────────────────
// CONFIGURATION - MOMENTUM
//───────────────────────────────────────────────────────────────────────────────

g_momentum = "═══════════ Momentum Filter ═══════════"
int     i_rsi_len       = input.int(14, "RSI Period", minval=5, maxval=30, group=g_momentum)
float   i_rsi_bull      = input.float(55, "RSI Bullish Level", minval=50, maxval=70, group=g_momentum)
float   i_rsi_bear      = input.float(45, "RSI Bearish Level", minval=30, maxval=50, group=g_momentum)
int     i_macd_fast     = input.int(12, "MACD Fast", minval=5, maxval=20, group=g_momentum)
int     i_macd_slow     = input.int(26, "MACD Slow", minval=15, maxval=50, group=g_momentum)
int     i_macd_sig      = input.int(9, "MACD Signal", minval=3, maxval=15, group=g_momentum)

//───────────────────────────────────────────────────────────────────────────────
// CONFIGURATION - STRUCTURE
//───────────────────────────────────────────────────────────────────────────────

g_structure = "═══════════ Structure ═══════════"
int     i_swing_left    = input.int(10, "Swing Left Bars", minval=3, maxval=30, group=g_structure)
int     i_swing_right   = input.int(5, "Swing Right Bars", minval=2, maxval=15, group=g_structure)
bool    i_require_struct = input.bool(true, "Require Structure Alignment", group=g_structure)

//───────────────────────────────────────────────────────────────────────────────
// CONFIGURATION - RISK MANAGEMENT
//───────────────────────────────────────────────────────────────────────────────

g_risk = "═══════════ Risk Management ═══════════"
float   i_risk_pct      = input.float(1.0, "Risk Per Trade %", minval=0.1, maxval=5.0, step=0.1, group=g_risk)
float   i_atr_stop_mult = input.float(2.0, "ATR Stop Multiplier", minval=1.0, maxval=5.0, step=0.5, group=g_risk)
float   i_rr_target1    = input.float(1.5, "R:R Target 1", minval=1.0, maxval=5.0, step=0.5, group=g_risk)
float   i_rr_target2    = input.float(2.5, "R:R Target 2", minval=1.5, maxval=8.0, step=0.5, group=g_risk)
float   i_trail_start   = input.float(1.0, "Trailing Start (R)", minval=0.5, maxval=3.0, step=0.5, group=g_risk)
float   i_trail_offset  = input.float(0.5, "Trailing Offset (R)", minval=0.2, maxval=2.0, step=0.1, group=g_risk)
float   i_channel_mult = input.float(3.0, "Channel Multiple", minval=1.0, maxval=10.0, step=0.5, group=g_risk)

g_frequency = "═══════════ Trade Frequency ═══════════"
bool    i_use_trade_limit = input.bool(true, "Use Daily Trade Limit", group=g_frequency)
int     i_max_trades    = input.int(30, "Max Daily Trades", minval=1, maxval=250, group=g_frequency)
int     i_cooldown      = input.int(1, "Signal Cooldown Bars", minval=0, maxval=50, group=g_frequency)
bool    i_require_close = input.bool(true, "Confirm On Bar Close", group=g_frequency)
bool    i_allow_flip    = input.bool(true, "Allow Flip / Re-Entry", group=g_frequency)

//───────────────────────────────────────────────────────────────────────────────
// CONFIGURATION - FILTERS
//───────────────────────────────────────────────────────────────────────────────

g_filters = "═══════════ Additional Filters ═══════════"
bool    i_use_vol_filter = input.bool(true, "Use Volume Filter", group=g_filters)
int     i_vol_len       = input.int(20, "Volume MA Period", minval=5, maxval=50, group=g_filters)
float   i_vol_mult      = input.float(1.0, "Volume Multiplier", minval=0.5, maxval=3.0, step=0.1, group=g_filters)
int     i_min_qual      = input.int(5, "Minimum Qualification Score", minval=3, maxval=10, group=g_filters)

g_mtf = "═══════════ MTF Bias ═══════════"
bool    i_use_mtf        = input.bool(true, "Use MTF Bias", group=g_mtf)
bool    i_mtf_filter     = input.bool(false, "Require MTF Alignment", group=g_mtf)
string  i_mtf_tf1        = input.timeframe("60", "MTF 1H", group=g_mtf)
string  i_mtf_tf2        = input.timeframe("240", "MTF 4H", group=g_mtf)
string  i_mtf_tf3        = input.timeframe("1D", "MTF 1D", group=g_mtf)
int     i_mtf_majority   = input.int(2, "MTF Majority", minval=1, maxval=3, group=g_mtf)

g_pressure = "═══════════ Pressure/Flow ═══════════"
bool    i_use_pressure   = input.bool(true, "Use Pressure Gauge", group=g_pressure)
int     i_pressure_len   = input.int(14, "Pressure Period", minval=5, maxval=50, group=g_pressure)
int     i_pressure_smooth = input.int(5, "Pressure Smoothing", minval=1, maxval=20, group=g_pressure)
int     i_pressure_mom   = input.int(10, "Pressure Momentum", minval=3, maxval=30, group=g_pressure)
float   i_pressure_high  = input.float(0.7, "Extreme Buy Level", minval=0.5, maxval=0.9, step=0.05, group=g_pressure)
float   i_pressure_low   = input.float(0.3, "Extreme Sell Level", minval=0.1, maxval=0.5, step=0.05, group=g_pressure)
float   i_pressure_thresh = input.float(0.05, "Momentum Threshold", minval=0.01, maxval=0.2, step=0.01, group=g_pressure)

g_squeeze = "═══════════ Squeeze/Volatility ═══════════"
bool    i_use_squeeze    = input.bool(true, "Use Squeeze Release", group=g_squeeze)
int     i_bb_len         = input.int(20, "BB Length", minval=10, maxval=50, group=g_squeeze)
float   i_bb_mult        = input.float(2.0, "BB Mult", minval=1.0, maxval=3.0, step=0.1, group=g_squeeze)
int     i_kc_len         = input.int(20, "KC Length", minval=10, maxval=50, group=g_squeeze)
float   i_kc_mult        = input.float(1.5, "KC Mult", minval=1.0, maxval=3.0, step=0.1, group=g_squeeze)

g_exits = "═══════════ Exit Scaling ═══════════"
bool    i_scale_out      = input.bool(true, "Scale Out at TP1", group=g_exits)
int     i_scale_pct      = input.int(50, "TP1 Size %", minval=10, maxval=90, group=g_exits)

//───────────────────────────────────────────────────────────────────────────────
// CONFIGURATION - VISUAL
//───────────────────────────────────────────────────────────────────────────────

g_adaptive = "═══════════ Regime Adaptation ═══════════"
bool    i_adapt_size    = input.bool(true, "Adaptive Position Sizing", group=g_adaptive)
float   i_trend_mult    = input.float(1.2, "Trending Regime Size Mult", minval=0.5, maxval=2.0, step=0.1, group=g_adaptive)
float   i_range_mult    = input.float(0.8, "Ranging Regime Size Mult", minval=0.3, maxval=1.0, step=0.1, group=g_adaptive)
bool    i_adapt_stops   = input.bool(true, "Adaptive Stop Distances", group=g_adaptive)
float   i_vol_stop_mult = input.float(1.3, "Volatile Stop Multiplier", minval=1.0, maxval=2.0, step=0.1, group=g_adaptive)

g_visual = "═══════════ Visual Settings ═══════════"
color   i_bull_col      = input.color(color.new(#00e676, 0), "Bullish Color", group=g_visual)
color   i_bull_glow     = input.color(color.new(#69f0ae, 0), "Bull Glow", group=g_visual)
color   i_bear_col      = input.color(color.new(#ff5252, 0), "Bearish Color", group=g_visual)
color   i_bear_glow     = input.color(color.new(#ff8a80, 0), "Bear Glow", group=g_visual)
color   i_neutral_col   = input.color(color.new(#546e7a, 0), "Neutral Color", group=g_visual)
color   i_trend_bg      = input.color(color.new(#00e676, 0), "Trend Regime BG", group=g_visual)
color   i_range_bg      = input.color(color.new(#7c4dff, 0), "Range Regime BG", group=g_visual)
color   i_vol_bg        = input.color(color.new(#ff5722, 0), "Volatile Regime BG", group=g_visual)
bool    i_show_dash     = input.bool(true, "Show Dashboard", group=g_visual)
bool    i_show_levels   = input.bool(true, "Show Trade Levels", group=g_visual)
bool    i_show_quality  = input.bool(true, "Show Signal Quality", group=g_visual)
bool    i_show_bg       = input.bool(false, "Show Background Shading", group=g_visual)

// New visual elements for institutional grade
bool    i_show_trend_band = input.bool(true, "Show Trend Band", group=g_visual)
bool    i_show_channel = input.bool(true, "Show Dynamic Channel", group=g_visual)
bool    i_show_signals = input.bool(true, "Show Clean Signals", group=g_visual)
bool    i_show_zones = input.bool(true, "Show S/R Zones", group=g_visual)
int     i_band_style = input.int(0, "Band Style", options=[0, 1, 2], group=g_visual)
int     i_signal_style = input.int(0, "Signal Style", options=[0, 1, 2], group=g_visual)

g_concepts = "═══════════ Institutional Concepts ═══════════"
bool    i_show_concepts = input.bool(true, "Show On-Chart Concepts", group=g_concepts)
bool    i_show_squeeze_boxes = input.bool(true, "Squeeze Zones (Boxes)", group=g_concepts)
bool    i_show_sweep_marks = input.bool(false, "Liquidity Sweeps (Marks)", group=g_concepts)
bool    i_show_structure_levels = input.bool(true, "Structure Levels", group=g_concepts)
bool    i_show_mtf_ribbon = input.bool(false, "MTF Bias Ribbon", group=g_concepts)

// Additional institutional elements
bool    i_show_fvg = input.bool(true, "Fair Value Gaps", group=g_concepts)
bool    i_show_order_blocks = input.bool(true, "Order Blocks", group=g_concepts)
bool    i_show_session_boxes = input.bool(true, "Session Boxes", group=g_concepts)

//───────────────────────────────────────────────────────────────────────────────
// REGIME DETECTION MODULE
//───────────────────────────────────────────────────────────────────────────────

f_adx_calc(int len) =>
    float tr_val = ta.tr(true)
    float plus_dm = math.max(high - high[1], 0)
    float minus_dm = math.max(low[1] - low, 0)
    if plus_dm > minus_dm
        minus_dm := 0
    else
        plus_dm := 0
    float smooth_tr = ta.rma(tr_val, len)
    float smooth_plus = ta.rma(plus_dm, len)
    float smooth_minus = ta.rma(minus_dm, len)
    float plus_di = smooth_tr > 0 ? 100 * smooth_plus / smooth_tr : 0
    float minus_di = smooth_tr > 0 ? 100 * smooth_minus / smooth_tr : 0
    float di_sum = plus_di + minus_di
    float dx = di_sum > 0 ? 100 * math.abs(plus_di - minus_di) / di_sum : 0
    float adx_val = ta.rma(dx, len)
    [adx_val, plus_di, minus_di]

[adx, plus_di, minus_di] = f_adx_calc(i_adx_len)

// ATR-based volatility regime
float atr_val = ta.atr(i_atr_len)
float atr_ma = ta.sma(atr_val, i_atr_len * 3)
float vol_ratio = atr_ma > 0 ? atr_val / atr_ma : 1.0

// Regime classification
// 0 = neutral, 1 = trending, 2 = ranging, 3 = volatile
int regime = 0
if vol_ratio >= i_vol_exp and adx < i_adx_trend
    regime := 3  // Volatile
else if adx >= i_adx_trend
    regime := 1  // Trending
else if vol_ratio <= i_vol_con
    regime := 2  // Ranging

// Regime filter for trading
bool regime_allows_trading = regime != 3 or not i_avoid_volatile
bool trending_regime = regime == 1
bool ranging_regime = regime == 2
bool volatile_regime = regime == 3

// Regime strength (0-100)
float regime_strength = 0.0
if trending_regime
    regime_strength := math.min(adx / 50.0 * 100, 100)
else if ranging_regime
    regime_strength := math.min((1 - vol_ratio) / (1 - i_vol_con) * 100, 100)
else if volatile_regime
    regime_strength := math.min(vol_ratio / i_vol_exp * 100, 100)
else
    regime_strength := 50.0

// Regime confidence for sizing
float regime_confidence = regime_strength / 100.0

//───────────────────────────────────────────────────────────────────────────────
// BIAS CALCULATION MODULE
//───────────────────────────────────────────────────────────────────────────────

float ma_fast = ta.ema(close, i_ma_fast)
float ma_slow = ta.ema(close, i_ma_slow)
float ma_trend = ta.ema(close, i_ma_trend)

// Bias scoring
float ma_spread = (ma_fast - ma_slow) / ma_slow * 100
bool ma_bullish = ma_fast > ma_slow and ma_slow > ma_trend
bool ma_bearish = ma_fast < ma_slow and ma_slow < ma_trend

// Price position bias
bool price_above_structure = close > ma_fast and close > ma_slow
bool price_below_structure = close < ma_fast and close < ma_slow

// Composite bias
float bias_score = 0.0
if ma_bullish
    bias_score += 30
if price_above_structure
    bias_score += 20
if close > ma_trend
    bias_score += 20
if plus_di > minus_di
    bias_score += 30

float bear_bias_score = 0.0
if ma_bearish
    bear_bias_score += 30
if price_below_structure
    bear_bias_score += 20
if close < ma_trend
    bear_bias_score += 20
if minus_di > plus_di
    bear_bias_score += 30

bool bullish_bias = bias_score >= i_bias_thresh
bool bearish_bias = bear_bias_score >= i_bias_thresh

//───────────────────────────────────────────────────────────────────────────────
// MOMENTUM MODULE
//───────────────────────────────────────────────────────────────────────────────

// RSI
float rsi = ta.rsi(close, i_rsi_len)
bool rsi_bullish = rsi > i_rsi_bull
bool rsi_bearish = rsi < i_rsi_bear
bool rsi_momentum_up = rsi > rsi[3]
bool rsi_momentum_down = rsi < rsi[3]

// MACD
float macd_line = ta.ema(close, i_macd_fast) - ta.ema(close, i_macd_slow)
float macd_signal = ta.ema(macd_line, i_macd_sig)
float macd_hist = macd_line - macd_signal

bool macd_bullish = macd_hist > 0 and macd_hist > macd_hist[1]
bool macd_bearish = macd_hist < 0 and macd_hist < macd_hist[1]

// Momentum scores
int momentum_bull_score = 0
if rsi_bullish
    momentum_bull_score += 1
if rsi_momentum_up
    momentum_bull_score += 1
if macd_bullish
    momentum_bull_score += 1

int momentum_bear_score = 0
if rsi_bearish
    momentum_bear_score += 1
if rsi_momentum_down
    momentum_bear_score += 1
if macd_bearish
    momentum_bear_score += 1

//───────────────────────────────────────────────────────────────────────────────
// PRESSURE & FLOW MODULE
//───────────────────────────────────────────────────────────────────────────────

float range_val = high - low
float raw_buy = range_val > 0 ? (close - low) / range_val : 0.5
float raw_sell = range_val > 0 ? (high - close) / range_val : 0.5
float pressure_ratio = ta.ema(raw_buy, i_pressure_len)
float pressure_smooth = ta.ema(pressure_ratio, i_pressure_smooth)
float pressure_momentum = pressure_smooth - pressure_smooth[i_pressure_mom]

int pressure_state = 0
if pressure_smooth >= i_pressure_high
    pressure_state := 2
else if pressure_smooth > 0.5 + i_pressure_thresh
    pressure_state := 1
else if pressure_smooth <= i_pressure_low
    pressure_state := -2
else if pressure_smooth < 0.5 - i_pressure_thresh
    pressure_state := -1

bool pressure_bull = i_use_pressure and (pressure_state >= 1 or pressure_momentum > i_pressure_thresh)
bool pressure_bear = i_use_pressure and (pressure_state <= -1 or pressure_momentum < -i_pressure_thresh)

//───────────────────────────────────────────────────────────────────────────────
// SQUEEZE MODULE
//───────────────────────────────────────────────────────────────────────────────

float bb_basis = ta.sma(close, i_bb_len)
float bb_dev = ta.stdev(close, i_bb_len) * i_bb_mult
float bb_upper = bb_basis + bb_dev
float bb_lower = bb_basis - bb_dev

float kc_basis = ta.ema(close, i_kc_len)
float kc_range = ta.atr(i_kc_len) * i_kc_mult
float kc_upper = kc_basis + kc_range
float kc_lower = kc_basis - kc_range

bool squeeze_on = bb_lower > kc_lower and bb_upper < kc_upper
bool squeeze_release = i_use_squeeze and squeeze_on[1] and not squeeze_on

//───────────────────────────────────────────────────────────────────────────────
// MULTI-TIMEFRAME MACD BIAS
//───────────────────────────────────────────────────────────────────────────────

f_macd_hist(series float src, int fast, int slow, int sig) =>
    float macd_val = ta.ema(src, fast) - ta.ema(src, slow)
    float macd_sig = ta.ema(macd_val, sig)
    macd_val - macd_sig

float mtf_hist_1 = request.security(syminfo.tickerid, i_mtf_tf1, f_macd_hist(close, i_macd_fast, i_macd_slow, i_macd_sig), lookahead=barmerge.lookahead_off)
float mtf_hist_2 = request.security(syminfo.tickerid, i_mtf_tf2, f_macd_hist(close, i_macd_fast, i_macd_slow, i_macd_sig), lookahead=barmerge.lookahead_off)
float mtf_hist_3 = request.security(syminfo.tickerid, i_mtf_tf3, f_macd_hist(close, i_macd_fast, i_macd_slow, i_macd_sig), lookahead=barmerge.lookahead_off)

int mtf_bull_count = (mtf_hist_1 > 0 ? 1 : 0) + (mtf_hist_2 > 0 ? 1 : 0) + (mtf_hist_3 > 0 ? 1 : 0)
int mtf_bear_count = (mtf_hist_1 < 0 ? 1 : 0) + (mtf_hist_2 < 0 ? 1 : 0) + (mtf_hist_3 < 0 ? 1 : 0)
bool mtf_bias_long = i_use_mtf and mtf_bull_count >= i_mtf_majority
bool mtf_bias_short = i_use_mtf and mtf_bear_count >= i_mtf_majority
bool mtf_allows_long = not i_mtf_filter or mtf_bias_long
bool mtf_allows_short = not i_mtf_filter or mtf_bias_short

//───────────────────────────────────────────────────────────────────────────────
// STRUCTURE MODULE
//───────────────────────────────────────────────────────────────────────────────

float swing_high = ta.pivothigh(high, i_swing_left, i_swing_right)
float swing_low = ta.pivotlow(low, i_swing_left, i_swing_right)

var float last_swing_high = na
var float last_swing_low = na

if not na(swing_high)
    last_swing_high := swing_high
if not na(swing_low)
    last_swing_low := swing_low

// Liquidity sweeps
bool sweep_high = not na(last_swing_high) and high > last_swing_high and close < last_swing_high
bool sweep_low = not na(last_swing_low) and low < last_swing_low and close > last_swing_low

// Structure alignment
bool above_swing_low = close > nz(last_swing_low, low)
bool below_swing_high = close < nz(last_swing_high, high)

// Structure scores
int struct_bull_score = 0
if above_swing_low
    struct_bull_score += 1
if close > ma_fast
    struct_bull_score += 1

int struct_bear_score = 0
if below_swing_high
    struct_bear_score += 1
if close < ma_fast
    struct_bear_score += 1

// Structure filter
bool struct_allows_long = not i_require_struct or struct_bull_score >= 1
bool struct_allows_short = not i_require_struct or struct_bear_score >= 1

//───────────────────────────────────────────────────────────────────────────────
// VOLUME MODULE
//───────────────────────────────────────────────────────────────────────────────

float vol_ma = ta.sma(volume, i_vol_len)
bool volume_confirm = not i_use_vol_filter or volume >= vol_ma * i_vol_mult

//───────────────────────────────────────────────────────────────────────────────
// COMPOSITE QUALIFICATION
//───────────────────────────────────────────────────────────────────────────────

// Total scores (max 14)
int max_score = 14
int bull_total = (
     (bullish_bias ? 3 : 0) + momentum_bull_score + struct_bull_score + (trending_regime ? 2 : 0) +
     (pressure_bull ? 1 : 0) + (sweep_low ? 1 : 0) + (squeeze_release ? 1 : 0) + (mtf_bias_long ? 1 : 0)
 )
int bear_total = (
     (bearish_bias ? 3 : 0) + momentum_bear_score + struct_bear_score + (trending_regime ? 2 : 0) +
     (pressure_bear ? 1 : 0) + (sweep_high ? 1 : 0) + (squeeze_release ? 1 : 0) + (mtf_bias_short ? 1 : 0)
 )

bool bull_qualified = bull_total >= i_min_qual
bool bear_qualified = bear_total >= i_min_qual

// Signal quality grading
f_signal_quality(int total, int max_total, bool bias, int momentum, int structure, bool trending, bool pressure, bool sweep, bool squeeze, bool mtf) =>
    float quality = 0.0
    quality += float(total) / float(max_total) * 50
    quality += bias ? 15 : 0
    quality += float(momentum) / 3.0 * 10
    quality += float(structure) / 2.0 * 10
    quality += trending ? 5 : 0
    quality += pressure ? 5 : 0
    quality += sweep ? 2.5 : 0
    quality += squeeze ? 2.5 : 0
    quality += mtf ? 5 : 0
    math.min(quality, 100)

float bull_quality = f_signal_quality(bull_total, max_score, bullish_bias, momentum_bull_score, struct_bull_score, trending_regime, pressure_bull, sweep_low, squeeze_release, mtf_bias_long)
float bear_quality = f_signal_quality(bear_total, max_score, bearish_bias, momentum_bear_score, struct_bear_score, trending_regime, pressure_bear, sweep_high, squeeze_release, mtf_bias_short)

// Quality grade
string bull_grade = bull_quality >= 80 ? "A" : bull_quality >= 60 ? "B" : bull_quality >= 40 ? "C" : "D"
string bear_grade = bear_quality >= 80 ? "A" : bear_quality >= 60 ? "B" : bear_quality >= 40 ? "C" : "D"

// Premium signals
bool bull_premium = bull_quality >= 75
bool bear_premium = bear_quality >= 75

//───────────────────────────────────────────────────────────────────────────────
// SIGNAL GENERATION
//───────────────────────────────────────────────────────────────────────────────

// Entry triggers
bool momentum_trigger_long = rsi_momentum_up and rsi > 50
bool momentum_trigger_short = rsi_momentum_down and rsi < 50
bool squeeze_trigger_long = squeeze_release and pressure_bull
bool squeeze_trigger_short = squeeze_release and pressure_bear
bool sweep_trigger_long = sweep_low
bool sweep_trigger_short = sweep_high

// Crossover/crossunder calls must execute consistently on every bar
bool cross_ma_long = ta.crossover(close, ma_fast)
bool cross_macd_long = ta.crossover(macd_hist, 0)
bool cross_ma_short = ta.crossunder(close, ma_fast)
bool cross_macd_short = ta.crossunder(macd_hist, 0)

bool bull_trigger = (
     cross_ma_long or cross_macd_long or momentum_trigger_long or
     squeeze_trigger_long or sweep_trigger_long
 )
bool bear_trigger = (
     cross_ma_short or cross_macd_short or momentum_trigger_short or
     squeeze_trigger_short or sweep_trigger_short
 )

// Cooldown tracking
var int bars_since_trade = 999
bars_since_trade := bars_since_trade + 1

// Daily trade count
var int daily_trades = 0
bool new_day = ta.change(time("D")) != 0
if new_day
    daily_trades := 0

bool within_trade_limit = not i_use_trade_limit or daily_trades < i_max_trades

bool entry_confirm = not i_require_close or barstate.isconfirmed

// Final entry conditions
bool long_entry = bull_qualified and bull_trigger and regime_allows_trading and 
                  struct_allows_long and volume_confirm and 
                  bars_since_trade >= i_cooldown and within_trade_limit and mtf_allows_long and
                  entry_confirm

bool short_entry = bear_qualified and bear_trigger and regime_allows_trading and 
                   struct_allows_short and volume_confirm and 
                   bars_since_trade >= i_cooldown and within_trade_limit and mtf_allows_short and
                   entry_confirm

//───────────────────────────────────────────────────────────────────────────────
// RISK CALCULATIONS
//───────────────────────────────────────────────────────────────────────────────

// Adaptive stop multiplier based on regime
float adaptive_stop_mult = i_atr_stop_mult
if i_adapt_stops
    if volatile_regime
        adaptive_stop_mult := i_atr_stop_mult * i_vol_stop_mult
    else if ranging_regime
        adaptive_stop_mult := i_atr_stop_mult * 0.85
    else if trending_regime
        adaptive_stop_mult := i_atr_stop_mult * 1.1

// Dynamic stop based on structure and ATR
float long_stop_struct = nz(last_swing_low, close - atr_val * adaptive_stop_mult)
float long_stop_atr = close - atr_val * adaptive_stop_mult
float long_stop = math.min(long_stop_struct, long_stop_atr)

float short_stop_struct = nz(last_swing_high, close + atr_val * adaptive_stop_mult)
float short_stop_atr = close + atr_val * adaptive_stop_mult
float short_stop = math.max(short_stop_struct, short_stop_atr)

// Risk amounts
float long_risk = close - long_stop
float short_risk = short_stop - close

// Target levels with adaptive multiplier
float adaptive_target_mult = 1.0
if vol_ratio >= i_vol_exp
    adaptive_target_mult := 1.3
else if vol_ratio <= i_vol_con
    adaptive_target_mult := 0.85

float long_tp1 = close + long_risk * i_rr_target1 * adaptive_target_mult
float long_tp2 = close + long_risk * i_rr_target2 * adaptive_target_mult
float short_tp1 = close - short_risk * i_rr_target1 * adaptive_target_mult
float short_tp2 = close - short_risk * i_rr_target2 * adaptive_target_mult

// Trailing activation and offset
float long_trail_start = close + long_risk * i_trail_start
float short_trail_start = close - short_risk * i_trail_start
float long_trail_offset = long_risk * i_trail_offset
float short_trail_offset = short_risk * i_trail_offset

//───────────────────────────────────────────────────────────────────────────────
// POSITION SIZING
//───────────────────────────────────────────────────────────────────────────────

// Regime-adaptive risk
float regime_size_mult = 1.0
if i_adapt_size
    if trending_regime
        regime_size_mult := i_trend_mult * regime_confidence
    else if ranging_regime
        regime_size_mult := i_range_mult
    else if volatile_regime
        regime_size_mult := 0.5  // Always reduce in volatile
    else
        regime_size_mult := 1.0

// Quality-adjusted sizing
float quality_mult = 1.0
if bull_premium or bear_premium
    quality_mult := 1.15  // Slight increase for premium signals

float account_risk = strategy.equity * (i_risk_pct / 100) * regime_size_mult * quality_mult
float long_position_size = long_risk > 0 ? account_risk / long_risk : 0
float short_position_size = short_risk > 0 ? account_risk / short_risk : 0

//───────────────────────────────────────────────────────────────────────────────
// TRADE EXECUTION
//───────────────────────────────────────────────────────────────────────────────

// Track entry prices and stops for trailing
var float entry_price = na
var float initial_stop = na
var float trailing_stop = na
var bool is_long = false
var bool is_short = false

// Long entry
if long_entry and (strategy.position_size == 0 or (i_allow_flip and strategy.position_size < 0))
    if strategy.position_size < 0
        strategy.close("Short")
    strategy.entry("Long", strategy.long, qty=long_position_size)
    entry_price := close
    initial_stop := long_stop
    trailing_stop := long_stop
    is_long := true
    is_short := false
    bars_since_trade := 0
    daily_trades := daily_trades + 1

// Short entry
if short_entry and (strategy.position_size == 0 or (i_allow_flip and strategy.position_size > 0))
    if strategy.position_size > 0
        strategy.close("Long")
    strategy.entry("Short", strategy.short, qty=short_position_size)
    entry_price := close
    initial_stop := short_stop
    trailing_stop := short_stop
    is_long := false
    is_short := true
    bars_since_trade := 0
    daily_trades := daily_trades + 1

// Trailing stop management
if strategy.position_size > 0 and is_long
    float profit = close - entry_price
    if profit >= long_risk * i_trail_start
        float new_trail = close - long_trail_offset
        if new_trail > trailing_stop
            trailing_stop := new_trail

if strategy.position_size < 0 and is_short
    float profit = entry_price - close
    if profit >= short_risk * i_trail_start
        float new_trail = close + short_trail_offset
        if new_trail < trailing_stop
            trailing_stop := new_trail

// Exit conditions
if strategy.position_size > 0
    if i_scale_out
        strategy.exit("Long TP1", "Long", limit=long_tp1, qty_percent=i_scale_pct)
    strategy.exit("Long Exit", "Long", stop=trailing_stop, limit=long_tp2)

if strategy.position_size < 0
    if i_scale_out
        strategy.exit("Short TP1", "Short", limit=short_tp1, qty_percent=i_scale_pct)
    strategy.exit("Short Exit", "Short", stop=trailing_stop, limit=short_tp2)

// Reset on flat
if strategy.position_size == 0
    entry_price := na
    initial_stop := na
    trailing_stop := na
    is_long := false
    is_short := false

//───────────────────────────────────────────────────────────────────────────────
// VISUALIZATION - Clean & Simple
//───────────────────────────────────────────────────────────────────────────────

// Simple gradient background based on trend
color trend_bg_color = ma_bullish ? color.new(i_bull_col, 95) : ma_bearish ? color.new(i_bear_col, 95) : color.new(i_neutral_col, 98)
bgcolor(i_show_bg ? trend_bg_color : na)

// Simple moving averages
color ma_color = ma_bullish ? i_bull_col : ma_bearish ? i_bear_col : i_neutral_col
plot(ma_fast, "Fast MA", color=color.new(ma_color, 50), linewidth=2)
plot(ma_slow, "Slow MA", color=color.new(ma_color, 70), linewidth=1)

// Clean entry signals - simple arrows
plotshape(long_entry, "Long", shape.triangleup, location.belowbar, 
          color=i_bull_col, size=size.small, textcolor=color.white, text="L")
plotshape(short_entry, "Short", shape.triangledown, location.abovebar, 
          color=i_bear_col, size=size.small, textcolor=color.white, text="S")

// Premium signals - simple star
plotshape(long_entry and bull_premium, "Premium Long", shape.diamond, location.belowbar, 
          color=#ffd700, size=size.tiny)
plotshape(short_entry and bear_premium, "Premium Short", shape.diamond, location.abovebar, 
          color=#ffd700, size=size.tiny)

//───────────────────────────────────────────────────────────────────────────────
// DASHBOARD
//───────────────────────────────────────────────────────────────────────────────

if i_show_dash and barstate.islast
    var table dash = table.new(position.top_right, 2, 13, bgcolor=color.new(#0d1117, 5),
                               border_width=1, border_color=color.new(#30363d, 40))
    
    string regime_text = switch regime
        1 => "TRENDING"
        2 => "RANGING"
        3 => "VOLATILE"
        => "NEUTRAL"
    color regime_col = regime == 1 ? i_bull_col : regime == 3 ? i_bear_col : i_neutral_col
    
    string pos_text = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    color pos_col = strategy.position_size > 0 ? i_bull_col : strategy.position_size < 0 ? i_bear_col : i_neutral_col
    
    table.cell(dash, 0, 0, "REGIME", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 0, regime_text, text_color=regime_col, text_size=size.small)
    
    table.cell(dash, 0, 1, "ADX", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(adx, "#.#"), text_color=adx >= i_adx_trend ? i_bull_col : i_neutral_col, text_size=size.small)
    
    table.cell(dash, 0, 2, "VOL RATIO", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(vol_ratio, "#.##"), text_color=color.new(#ffa726, 0), text_size=size.small)
    
    table.cell(dash, 0, 3, "BULL SCORE", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(bull_total) + "/" + str.tostring(max_score), text_color=bull_qualified ? i_bull_col : i_neutral_col, text_size=size.small)
    
    table.cell(dash, 0, 4, "BEAR SCORE", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(bear_total) + "/" + str.tostring(max_score), text_color=bear_qualified ? i_bear_col : i_neutral_col, text_size=size.small)
    
    table.cell(dash, 0, 5, "RSI", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(rsi, "#.#"), text_color=rsi > 50 ? i_bull_col : i_bear_col, text_size=size.small)
    
    table.cell(dash, 0, 6, "POSITION", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 6, pos_text, text_color=pos_col, text_size=size.small)
    
    table.cell(dash, 0, 7, "DAILY TRADES", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(daily_trades) + "/" + str.tostring(i_max_trades), text_color=color.new(#78909c, 0), text_size=size.small)
    
    if strategy.position_size != 0
        float unrealized_pnl = strategy.position_size > 0 ? (close - entry_price) : (entry_price - close)
        float unrealized_pct = entry_price > 0 ? unrealized_pnl / entry_price * 100 : 0
        table.cell(dash, 0, 8, "UNREALIZED", text_color=color.new(#b2b5be, 0), text_size=size.small)
        table.cell(dash, 1, 8, str.tostring(unrealized_pct, "#.##") + "%", 
                   text_color=unrealized_pnl > 0 ? i_bull_col : i_bear_col, text_size=size.small)
        
        table.cell(dash, 0, 9, "TRAIL STOP", text_color=color.new(#b2b5be, 0), text_size=size.small)
        table.cell(dash, 1, 9, str.tostring(trailing_stop, "#.##"), text_color=color.new(#ffa726, 0), text_size=size.small)
    
    // Additional metrics
    table.cell(dash, 0, 10, "REGIME STR", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 10, str.tostring(regime_strength, "#") + "%", text_color=regime_col, text_size=size.small)
    
    table.cell(dash, 0, 11, "SIZE MULT", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 11, str.tostring(regime_size_mult, "#.##") + "x", text_color=color.new(#e91e63, 0), text_size=size.small)
    
    string quality_text = bull_quality > bear_quality ? bull_grade + " (" + str.tostring(bull_quality, "#") + "%)" : bear_grade + " (" + str.tostring(bear_quality, "#") + "%)"
    color quality_col = bull_quality > bear_quality ? (bull_premium ? color.new(#ffd700, 0) : i_bull_col) : (bear_premium ? color.new(#ffd700, 0) : i_bear_col)
    table.cell(dash, 0, 12, "QUALITY", text_color=color.new(#b2b5be, 0), text_size=size.small)
    table.cell(dash, 1, 12, quality_text, text_color=quality_col, text_size=size.small)
