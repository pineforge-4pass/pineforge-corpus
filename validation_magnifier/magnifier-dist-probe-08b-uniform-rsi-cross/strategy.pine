// Magnifier distribution probe 08b — UNIFORM, RSI-cross entry
//
// Purpose: companion to 08a (ENDPOINTS). Identical Pine source; the
// harness/build override switches MagnifierDistribution to UNIFORM
// to expose tick-density divergence on the same intra-bar fill
// scenario. TV always uses ENDPOINTS so any 08b-vs-08a delta is the
// codepath signal we want to land.
//
// Trade shape: long-only RSI(14) cross-up through 50; mid-bar
// protective stop at (open+high)/2. Exit on RSI cross-down through 50.
//
// TV setup: 15m chart, ETH-USDT-USDT, magnifier ON. TV export is the
// ENDPOINTS baseline (use 08a/trades.csv); the UNIFORM run is
// harness-only and produces the divergence under test.
//@version=6
strategy("PF magnifier dist probe 08b - UNIFORM RSI cross", shorttitle="MAG_08b_UNI", overlay=true,
     initial_capital=1000000, currency=currency.USD, use_bar_magnifier=true,
     commission_type=strategy.commission.percent, commission_value=0, slippage=0,
     default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=1,
     process_orders_on_close=false)

rsiVal = ta.rsi(close, 14)

bool entryCond = ta.crossover(rsiVal, 50.0)
bool exitCond  = ta.crossunder(rsiVal, 50.0)

if entryCond and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty=1, comment="entry long")
    float stopLvl = (open + high) * 0.5
    strategy.exit("X", from_entry="L", stop=stopLvl, comment="mid-bar stop")

if exitCond and strategy.position_size > 0
    strategy.close("L", comment="exit long")
